# Copy this file to .env to override defaults (Vite loads it automatically).

# Backend base URL. Defaults to http://localhost:8000 if unset.
# VITE_API_URL=http://localhost:8000

# WebSocket base URL. Defaults to VITE_API_URL with http -> ws.
# VITE_WS_URL=ws://localhost:8000

# Note: the Google Client ID is NOT set here. The frontend fetches it from the
# backend at /api/auth/config, so configure GOOGLE_CLIENT_ID in backend/.env only.
