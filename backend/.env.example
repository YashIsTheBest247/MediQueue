# Copy this file to .env and fill in your values.

# Secret used to sign session tokens. Use a long random string in production.
MEDIQUEUE_SECRET=change-me-to-a-long-random-secret

# Google OAuth Client ID (Google Cloud Console > Credentials > OAuth client ID > Web application).
# Leave blank to disable Google sign-in (email/password still works).
GOOGLE_CLIENT_ID=

# Optional: path to the SQLite database file (defaults to backend/mediqueue.db).
# MEDIQUEUE_DB=mediqueue.db
