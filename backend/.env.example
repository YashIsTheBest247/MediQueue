# Copy this file to .env and fill in your values.

# Secret used to sign session tokens. Use a long random string in production.
MEDIQUEUE_SECRET=change-me-to-a-long-random-secret

# Google OAuth Client ID (Google Cloud Console > Credentials > OAuth client ID > Web application).
# Leave blank to disable Google sign-in (email/password still works).
GOOGLE_CLIENT_ID=

# Optional: path to the SQLite database file (defaults to backend/mediqueue.db).
# MEDIQUEUE_DB=mediqueue.db

# Email notifications ("you're next" alert sent to the patient when the token
# ahead of theirs is called). Leave SMTP host/user/pass blank to disable email.
MEDIQUEUE_SMTP_HOST=
MEDIQUEUE_SMTP_PORT=587
MEDIQUEUE_SMTP_USER=
MEDIQUEUE_SMTP_PASS=
# Set to true if your provider uses implicit SSL (port 465) instead of STARTTLS.
MEDIQUEUE_SMTP_SSL=false
# From address shown on the email (defaults to the SMTP user).
MEDIQUEUE_MAIL_FROM=
